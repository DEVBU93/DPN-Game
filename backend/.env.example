# ─────────────────────────────────────────────────────────────
# DEVBUPLAYTIME — Variables de entorno
# Copia este archivo a: backend/.env
# ─────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
DATABASE_URL="postgresql://devbu:devbu_secret@localhost:5432/devbuplaytime_db"

# JWT Seguridad (cambia estos valores en producción)
JWT_SECRET="DevbuPlaytime_SuperSecret_2024_LaManada!"
JWT_REFRESH_SECRET="DevbuPlaytime_Refresh_SuperSecret_2024!"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Logs
LOG_LEVEL=info
